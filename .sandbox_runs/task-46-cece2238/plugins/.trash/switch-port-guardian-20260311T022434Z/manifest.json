{
  "plugin_id": "switch-port-guardian",
  "name": "交换机端口守护",
  "version": "0.1.0",
  "runtime": "python",
  "entrypoint": "main.py",
  "enabled": false,
  "capabilities": [
    "network.inspect",
    "task.submit"
  ],
  "permissions": {},
  "schedules": [
    {
      "name": "巡检任务",
      "cron": "0 */5 * * * *",
      "task_template_key": "switch_inspect"
    }
  ],
  "task_templates": [
    {
      "key": "switch_inspect",
      "title": "交换机端口巡检",
      "risk_level": "medium",
      "task_type": "feature",
      "payload": {
        "target": "core-switch"
      }
    }
  ]
}